<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.joyshot.app.mapper.RoleMapper">

    <resultMap id="BaseResultMap" type="com.joyshot.app.entity.Role">
        <id property="id" column="id" jdbcType="INTEGER"/>
        <result property="name" column="name" jdbcType="VARCHAR"/>
        <result property="engName" column="eng_name" jdbcType="VARCHAR"/>
        <result property="description" column="description" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,name,eng_name,
        description
    </sql>

    <select id="selectRoleById" resultType="com.joyshot.app.entity.Role">
        select *
        from role where id = #{id}
    </select>
</mapper>
