    </select>

    <select id="selectOrderHasCoupon" resultMap="orderWithAffiliate">
        select o.*, aff.id affid, aff.name, aff.nick_name, aff.phone
        from js_order o, coupon c, affiliate aff
        <where>
            <if test="1 == 1">
                and o.coupon_code = c.coupon_code
                and aff.id = c.coupon_owner
            </if>
            <if test="queryField != '' and queryField == 'name'">
                and ( aff.name like concat('%', #{keyword}, '%') or aff.nick_name like concat('%', #{keyword}, '%') )
            </if>
            <if test="queryField != '' and queryField == 'coupon_code'">
                and c.coupon_code like concat('%', #{keyword}, '%')
            </if>
        </where>
        order by o.id desc
    </select>

    <select id="findClosingOrder" resultMap="BaseResultMap1">
        select o.*,
               p.nick_name, p.name, p.id ph_id, p.go_live, p.email email2,
               b.id bank_id, b.bank_code, b.bank, b.bank_branch, b.name bank_account_name, b.account bank_account
        from js_order o, photographer p, photographer_bank b
        where o.ph_uuid = p.ph_uuid
          and p.id = b.ph_id
          and o.status = 'confirm-uploaded'
    </select>

    <select id="findOrderInContact" resultMap="BaseResultMap1">
        select o.*, p.nick_name, p.name, p.id ph_id, p.go_live, p.email email2
        from js_order o, photographer p
        <where>
            <if test="1 == 1">
                and o.ph_uuid = p.ph_uuid
                and o.status = 'contact'
            </if>
            and DATE_ADD( str_to_date( CONCAT(o.shooting_date, ' ',  o.shooting_time), '%Y/%m/%d %H:%i') ,interval (shooting_duration * 60 + 18*60) minute) &lt; str_to_date( #{endDate}, '%Y/%m/%d %H:%i')
        </where>
        order by o.id desc
    </select>


    <select id="selectOrderByPhUuid" resultMap="BaseResultMap">
