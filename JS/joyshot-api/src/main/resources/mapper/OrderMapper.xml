    <select id="findOrderNotPaid" resultMap="BaseResultMap">
        select o.*, p.nick_name, p.name, p.id ph_id, p.go_live, p.email email2
        from js_order o, photographer p
        <where>
            <if test="1 == 1">
                and o.ph_uuid = p.ph_uuid
                and o.status = 'processing'
                and o.manual_order is null
            </if>
            and o.created_at  &gt;= str_to_date( #{startDate}, '%Y/%m/%d %H:%i')
            and o.created_at &lt; str_to_date( #{endDate}, '%Y/%m/%d %H:%i')
        </where>
        order by o.id desc
    </select>

