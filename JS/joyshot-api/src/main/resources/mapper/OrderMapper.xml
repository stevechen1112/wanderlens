    <select id="selectByPage" resultMap="BaseResultMap">
        select o.*, p.nick_name, p.name, p.id ph_id, p.go_live, p.email email2
        from js_order o, photographer p
        <where>
            <if test="1 == 1">
                and o.ph_uuid = p.ph_uuid
            </if>
            <if test="queryField != '' and queryField == 'customerName'">
                    and o.customer_name like concat('%', #{keyword}, '%')
            </if>
            <if test="queryField != '' and queryField == 'customerPhone'">
                    and o.customer_phone like concat('%', #{keyword}, '%')
            </if>
            <if test="queryField != '' and queryField == 'orderNo'">
                and o.order_no like concat('%', #{keyword}, '%')
            </if>
            <if test="queryField != '' and queryField == 'photograhperName'">
                and (p.name like concat('%', #{keyword}, '%') or p.nick_name like concat('%', #{keyword}, '%'))
            </if>
        </where>
        order by o.id desc
    </select>

    <select id="findShootingDateTime24HourLater" resultMap="BaseResultMap">
        select  o.*, p.nick_name, p.name, p.id ph_id, p.go_live, p.email email2
        from js_order o, photographer p
        where o.ph_uuid = p.ph_uuid
        and status in ('pay_success', 'contact')
        and str_to_date( concat(shooting_date, ' ', shooting_time ) , "%Y/%m/%d %H:%i") &gt;= str_to_date( #{startDate}, '%Y/%m/%d %H:%i')
        and str_to_date( concat(shooting_date, ' ', shooting_time ) , "%Y/%m/%d %H:%i") &lt; str_to_date( #{endDate}, '%Y/%m/%d %H:%i')
    </select>

    <select id="findShootingDateTimeAfter12Hour" resultMap="BaseResultMap">
        select  o.*, p.nick_name, p.name, p.id ph_id, p.go_live, p.email email2
