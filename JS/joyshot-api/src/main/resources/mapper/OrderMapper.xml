    </select>

    <select id="selectMyOrder" resultMap="BaseResultMap">
        select o.*, p.nick_name, p.name, p.id ph_id, p.go_live, p.email email2
        from js_order o, photographer p
        <where>
            <if test="1 == 1">
                and o.ph_uuid = p.ph_uuid
                and p.id = #{photographerId}
                and (o.status not in ('processing','auto_cancel','pay_failed','cancel') or o.manual_order='Y')
            </if>
            <if test="queryField != '' and queryField == 'customerName'">
                and o.customer_name like concat('%', #{keyword}, '%')
            </if>
            <if test="queryField != '' and queryField == 'customerPhone'">
                and o.customer_phone like concat('%', #{keyword}, '%')
            </if>
            <if test="queryField != '' and queryField == 'orderNo'">
                and o.order_no like concat('%', #{keyword}, '%')
            </if>
        </where>
        order by o.shooting_date desc
    </select>

