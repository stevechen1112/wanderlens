<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.joyshot.app.mapper.PhotographerRatingMapper">

    <resultMap id="BaseResultMap" type="com.joyshot.app.entity.PhotographerRating">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="phId" column="ph_id" jdbcType="INTEGER"/>
            <result property="comments" column="comments" jdbcType="VARCHAR"/>
            <result property="stars" column="stars" jdbcType="INTEGER"/>
            <result property="author" column="author" jdbcType="INTEGER"/>
            <result property="createdBy" column="created_by" jdbcType="VARCHAR"/>
            <result property="createdAt" column="created_at" jdbcType="TIMESTAMP"/>
            <result property="modifiedAt" column="modified_at" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,ph_id,comments,
        stars,created_by,created_at,
        modified_at,author
    </sql>
    <select id="selectRatingByPid" resultMap="BaseResultMap">
        select * from photographer_rating where ph_id = #{phId}
    </select>

    <select id="selectLatest" resultMap="BaseResultMap">
        SELECT * from photographer_rating order by created_at desc
    </select>
</mapper>
