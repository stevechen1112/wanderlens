<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.joyshot.app.mapper.FileRepoMapper">

    <resultMap id="BaseResultMap" type="com.joyshot.app.entity.FileRepo">
        <id property="id" column="id" jdbcType="INTEGER"/>
        <result property="name" column="name" jdbcType="VARCHAR"/>
        <result property="type" column="type" jdbcType="VARCHAR"/>
        <result property="size" column="size" jdbcType="BIGINT"/>
        <result property="url" column="url" jdbcType="VARCHAR"/>
        <result property="fileUsage" column="file_usage" jdbcType="VARCHAR"/>
        <result property="fileObj" column="file_obj" />
        <result property="isDeleted" column="is_deleted" jdbcType="TINYINT"/>
        <result property="enable" column="enable" jdbcType="TINYINT"/>
        <result property="createdAt" column="created_at" jdbcType="TIMESTAMP"/>
        <result property="modifiedAt" column="modified_at" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,name,type,
        size,url,is_deleted,
        enable, file_obj, file_usage, created_at, modified_at
    </sql>

    <insert id="insertFile" useGeneratedKeys="true" keyProperty="id" parameterType="com.joyshot.app.entity.FileRepo">
        insert into file_repo
        ( name, type, size, url, uuid, file_obj, file_usage)
        values ( #{name},
        #{type},
        #{size},
        #{url},
        #{uuid},
        #{multipartFile.bytes,jdbcType=BLOB},
        #{fileUsage})
    </insert>
</mapper>
