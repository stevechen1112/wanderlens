# WanderLens demo — wanderlenstw.com
# 複製為 wanderlens-infra/.env 後填入密碼（勿 commit）

# ── MySQL ──
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT
MYSQL_DATABASE=wanderlens_db
MYSQL_USER=wanderlens
MYSQL_PASSWORD=CHANGE_ME_STRONG_APP

# ── Redis ──
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS

# ── MinIO（demo 可同機；正式建議 S3）──
MINIO_ROOT_USER=wanderlens
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO
MEDIA_SERVICE_API_KEY=CHANGE_ME_STRONG_MEDIA_KEY

# ── API ──
API_JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET
API_JWT_EXPIRATION=28800
FRONTEND_WEB_URL=https://www.wanderlenstw.com
ECPAY_RETURN_URL=https://api.wanderlenstw.com/api/payment/ecpay/callback
LINE_WEBHOOK_URL=https://api.wanderlenstw.com/api/line/webhook

# ── 綠界（demo 可沿用測試商店或留空）──
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_MODE=Test
STAGING_PAYMENT_SIMULATE=true

# ── Google（Places 搜尋；無 key 則部分 E2E/功能 skip）──
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=

# ── 對外網域（build / CORS 參考）──
PUBLIC_API_BASE=https://api.wanderlenstw.com/api
PUBLIC_WWW=https://www.wanderlenstw.com
PUBLIC_APP_WEB=https://app.wanderlenstw.com
PUBLIC_PAPP_WEB=https://papp.wanderlenstw.com
