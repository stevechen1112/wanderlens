# ──────────────────────────────────────────────
# WanderLens 開發環境變數
# ──────────────────────────────────────────────
# 複製此檔案為 .env.dev 後修改實際值
# cp .env.dev.example .env.dev

# ── MySQL ──
MYSQL_ROOT_PASSWORD=change-me-to-strong-password
MYSQL_DATABASE=wanderlens_db
MYSQL_USER=wanderlens
MYSQL_PASSWORD=change-me-to-strong-password

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-to-strong-redis-password

# ── MinIO（S3 相容物件儲存）──
MINIO_ROOT_USER=wanderlens
MINIO_ROOT_PASSWORD=change-me-to-strong-password
MINIO_ENDPOINT=http://localhost:9000

# ── 服務間認證 ──
MEDIA_SERVICE_API_KEY=change-me-to-strong-service-key

# ── API 後端 ──
API_PORT=8080
API_JWT_SECRET=change-this-in-production
API_JWT_EXPIRATION=28800

# ── 綠界 ECPay（開發環境用測試商店）──
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_RETURN_URL=http://localhost/api/payment/ecpay/callback

# ── LINE Messaging API（取代 LINE Notify）──
LINE_CHANNEL_ACCESS_TOKEN=
LINE_WEBHOOK_URL=http://localhost/api/line/webhook

# ── Google API ──
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# ── SMS（dev 用 Twilio）──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Email SMTP ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@wanderlens.app

# ── 前端 Port ──
WEB_PORT=3001
PROVIDER_PORT=3002
ADMIN_PORT=3003
MEDIA_PORT=3004

# ── 分析追蹤 ──
GA_TRACKING_ID=
META_PIXEL_ID=