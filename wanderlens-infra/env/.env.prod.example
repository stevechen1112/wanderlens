# ──────────────────────────────────────────────
# WanderLens 正式環境變數
# ──────────────────────────────────────────────
# 所有敏感值必須從 Secret Manager 注入，不可提交 Git

# ── MySQL ──
MYSQL_ROOT_PASSWORD=${SECRET_MYSQL_ROOT_PASSWORD}
MYSQL_DATABASE=wanderlens_db
MYSQL_USER=wanderlens
MYSQL_PASSWORD=${SECRET_MYSQL_PASSWORD}

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── 物件儲存（正式環境用 AWS S3 或 GCS）──
S3_ACCESS_KEY=${SECRET_S3_ACCESS_KEY}
S3_SECRET_KEY=${SECRET_S3_SECRET_KEY}
S3_REGION=ap-northeast-1
S3_BUCKET_RAW=wanderlens-raw
S3_BUCKET_JPEG=wanderlens-jpeg
S3_BUCKET_AI=wanderlens-ai-output

# ── API 後端 ──
API_JWT_SECRET=${SECRET_JWT_SECRET}
API_JWT_EXPIRATION=28800

# ── 綠界 ECPay ──
ECPAY_MERCHANT_ID=${SECRET_ECPAY_MERCHANT_ID}
ECPAY_HASH_KEY=${SECRET_ECPAY_HASH_KEY}
ECPAY_HASH_IV=${SECRET_ECPAY_HASH_IV}
ECPAY_RETURN_URL=https://api.wanderlens.app/api/payment/ecpay/callback

# ── LINE Messaging API ──
LINE_CHANNEL_ACCESS_TOKEN=${SECRET_LINE_CHANNEL_ACCESS_TOKEN}
LINE_WEBHOOK_URL=https://api.wanderlens.app/api/line/webhook

# ── Google API ──
GOOGLE_MAPS_API_KEY=${SECRET_GOOGLE_MAPS_API_KEY}
GOOGLE_PLACES_API_KEY=${SECRET_GOOGLE_PLACES_API_KEY}

# ── SMS（prod 用三竹）──
MITAKE_USERNAME=${SECRET_MITAKE_USERNAME}
MITAKE_PASSWORD=${SECRET_MITAKE_PASSWORD}

# ── Email SMTP ──
SMTP_HOST=mail.wanderlens.app
SMTP_PORT=587
SMTP_USERNAME=${SECRET_SMTP_USERNAME}
SMTP_PASSWORD=${SECRET_SMTP_PASSWORD}
SMTP_FROM=noreply@wanderlens.app